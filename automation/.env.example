# n8n runtime
N8N_IMAGE=docker.n8n.io/n8nio/n8n:2.2.6
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/
PUBLIC_WEBHOOK_BASE_URL=http://localhost:5678
INTERNAL_WEBHOOK_BASE_URL=http://n8n-main:5678
STATIC_SITE_BASE_URL=http://127.0.0.1:8000
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=replace-with-a-32-char-secret
GENERIC_TIMEZONE=Europe/Istanbul
TZ=Europe/Istanbul

# n8n persistence
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me

# AI provider
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=Yankura <hello@yankura.co>
YANKURA_REPLY_TO=hello@yankura.co

# Notifications
SLACK_WEBHOOK_URL=
SLACK_WEBHOOK_NEW_PROPOSAL=
SLACK_WEBHOOK_CONTENT=
SLACK_WEBHOOK_STRATEGY=
SLACK_WEBHOOK_OPERATIONS=
SLACK_WEBHOOK_ALERTS=

# Notion
NOTION_API_KEY=
NOTION_API_VERSION=2022-06-28
NOTION_LEADS_DATABASE_ID=
NOTION_CONTENT_CALENDAR_DATABASE_ID=
NOTION_REPORTS_DATABASE_ID=
NOTION_COMPETITOR_ANALYSIS_DATABASE_ID=
NOTION_BRIEFS_DATABASE_ID=

# Google service account
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DELEGATED_USER=
GOOGLE_DRIVE_PROPOSALS_FOLDER_ID=
GOOGLE_DRIVE_REPORTS_FOLDER_ID=
GOOGLE_DRIVE_CLIENTS_ROOT_FOLDER_ID=
GOOGLE_SLIDES_TEMPLATE_ID=
GOOGLE_SHEETS_REPORTING_SPREADSHEET_ID=
GOOGLE_SHEETS_REPORTING_RANGE=Raw!A:I

# Meta ads
META_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v23.0

# Competitive analysis
APIFY_TOKEN=
COMPETITOR_APIFY_ACTOR=apify~instagram-scraper
COMPETITOR_APIFY_INPUT_FIELD=usernames
